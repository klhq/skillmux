{
  "name": "skill-router",
  "version": "0.1.0",
  "description": "Local read-only MCP server routing natural-language task queries to skills in a SKILL.md vault, with zero-loss delivery",
  "type": "module",
  "private": false,
  "author": "Lance Hsu <lance@klh.app>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klhq/skill-router.git"
  },
  "bugs": {
    "url": "https://github.com/klhq/skill-router/issues"
  },
  "homepage": "https://github.com/klhq/skill-router#readme",
  "bin": {
    "skill-router": "./src/cli.ts"
  },
  "scripts": {
    "test": "bun test",
    "serve": "bun run src/cli.ts serve",
    "index": "bun run src/cli.ts index",
    "eval": "bun run src/cli.ts eval",
    "doctor": "bun run src/cli.ts doctor",
    "models:download": "bun run src/cli.ts models download",
    "build": "bun build --compile src/cli.ts --outfile dist/skill-router"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "trustedDependencies": [
    "onnxruntime-node",
    "protobufjs"
  ]
}
